{
  "description": "Kubernetes Node vs Pod Metrics — Separated View",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["kubernetes", "k8s", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {"text": "Mimir-Nodes-Tenant", "value": "mimir-nodes"},
        "includeAll": false,
        "label": "Node Datasource",
        "name": "ds_nodes",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {"text": "Mimir-Pods-Tenant", "value": "mimir-pods"},
        "includeAll": false,
        "label": "Pod Datasource",
        "name": "ds_pods",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {"text": "ecommerce", "value": "ecommerce"},
        "includeAll": false,
        "label": "Namespace",
        "name": "namespace",
        "options": [
          {"text": "ecommerce", "value": "ecommerce", "selected": true},
          {"text": "monitoring", "value": "monitoring"},
          {"text": "kube-system", "value": "kube-system"}
        ],
        "type": "custom",
        "query": "ecommerce,monitoring,kube-system"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "Asia/Jakarta",
  "title": "☸️ Kubernetes: Node vs Pod Metrics",
  "uid": "k8s-node-vs-pod",
  "version": 2,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "🖥️ NODE METRICS (Server Health) — datasource: $ds_nodes",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_nodes}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "#3b82f6", "mode": "fixed"},
          "mappings": [],
          "max": 100, "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${ds_nodes}"}, "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "instant": true, "refId": "A"}],
      "title": "💻 Node CPU Usage",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_nodes}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "#10b981", "mode": "fixed"},
          "mappings": [],
          "max": 100, "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${ds_nodes}"}, "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "instant": true, "refId": "A"}],
      "title": "🧠 Node Memory Usage",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_nodes}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "#f59e0b", "mode": "fixed"},
          "mappings": [],
          "max": 100, "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${ds_nodes}"}, "expr": "100 - (avg(node_filesystem_avail_bytes{mountpoint=\"/\", fstype!=\"tmpfs\"}) / avg(node_filesystem_size_bytes{mountpoint=\"/\", fstype!=\"tmpfs\"}) * 100)", "instant": true, "refId": "A"}],
      "title": "💾 Node Disk Usage",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_nodes}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "#ec4899", "mode": "fixed"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 2}, {"color": "red", "value": 4}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${ds_nodes}"}, "expr": "avg(node_load1)", "instant": true, "refId": "A"}],
      "title": "📊 Node Load (1min)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_nodes}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never"},
          "unit": "percent", "max": 100, "min": 0
        }
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 6},
      "id": 20,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${ds_nodes}"}, "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU Usage", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${ds_nodes}"}, "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "legendFormat": "Memory Usage", "refId": "B"}
      ],
      "title": "📈 Node CPU & Memory Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_nodes}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never"},
          "unit": "Bps"
        }
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 6},
      "id": 21,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${ds_nodes}"}, "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|flannel.*|cali.*|cbr.*\"}[5m]))", "legendFormat": "⬇️ RX", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${ds_nodes}"}, "expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|flannel.*|cali.*|cbr.*\"}[5m]))", "legendFormat": "⬆️ TX", "refId": "B"}
      ],
      "title": "🌐 Node Network I/O",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "id": 101,
      "title": "📦 POD METRICS — Namespace: $namespace — datasource: $ds_pods",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_pods}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "#10b981", "mode": "fixed"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 14},
      "id": 5,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${ds_pods}"}, "expr": "count(count by (pod) (container_cpu_usage_seconds_total{namespace=\"${namespace}\", container!=\"\", container!=\"POD\"}))", "instant": true, "refId": "A"}],
      "title": "✅ Active Pods",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_pods}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "#f59e0b", "mode": "fixed"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "yellow", "value": 0}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 14},
      "id": 7,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${ds_pods}"}, "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"${namespace}\", container!=\"\", container!=\"POD\"}[5m])) * 1000", "instant": true, "refId": "A"}],
      "title": "💻 Total Pod CPU (millicores)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_pods}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "#3b82f6", "mode": "fixed"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": 0}]},
          "unit": "bytes"
        }
      },
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 14},
      "id": 8,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${ds_pods}"}, "expr": "sum(container_memory_working_set_bytes{namespace=\"${namespace}\", container!=\"\", container!=\"POD\"})", "instant": true, "refId": "A"}],
      "title": "🧠 Total Pod Memory",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_pods}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"group": "A", "mode": "normal"}
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "id": 9,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "${ds_pods}"}, "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"${namespace}\", container!=\"\", container!=\"POD\"}[5m])) * 1000", "legendFormat": "{{pod}}", "refId": "A"}],
      "title": "💻 CPU per Pod (millicores)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_pods}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"group": "A", "mode": "normal"}
          },
          "unit": "bytes"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "id": 10,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "${ds_pods}"}, "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"${namespace}\", container!=\"\", container!=\"POD\"})", "legendFormat": "{{pod}}", "refId": "A"}],
      "title": "🧠 Memory per Pod",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 26},
      "id": 102,
      "title": "🌐 Pod Network & ⚠️ Throttling",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_pods}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never"},
          "unit": "Bps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 27},
      "id": 12,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${ds_pods}"}, "expr": "sum by (pod) (rate(container_network_receive_bytes_total{namespace=\"${namespace}\"}[5m]))", "legendFormat": "⬇️ {{pod}}", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${ds_pods}"}, "expr": "sum by (pod) (rate(container_network_transmit_bytes_total{namespace=\"${namespace}\"}[5m]))", "legendFormat": "⬆️ {{pod}}", "refId": "B"}
      ],
      "title": "🌐 Network I/O per Pod",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_pods}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 27},
      "id": 13,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${ds_pods}"}, "expr": "100 * sum by (pod) (rate(container_cpu_cfs_throttled_periods_total{namespace=\"${namespace}\", container!=\"\", container!=\"POD\"}[5m])) / sum by (pod) (rate(container_cpu_cfs_periods_total{namespace=\"${namespace}\", container!=\"\", container!=\"POD\"}[5m]))", "legendFormat": "{{pod}}", "refId": "A"}],
      "title": "⚠️ CPU Throttling %",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 35},
      "id": 103,
      "title": "📋 Pod Resource Table",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${ds_pods}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"align": "auto", "displayMode": "auto", "filterable": true},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "CPU (m)"}, "properties": [{"id": "unit", "value": "short"}, {"id": "custom.width", "value": 120}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}, {"id": "custom.displayMode", "value": "color-background-solid"}]},
          {"matcher": {"id": "byName", "options": "Memory (MB)"}, "properties": [{"id": "unit", "value": "short"}, {"id": "decimals", "value": 1}, {"id": "custom.width", "value": 130}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 200}, {"color": "red", "value": 500}]}}, {"id": "custom.displayMode", "value": "color-background-solid"}]}
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 36},
      "id": 11,
      "options": {"showHeader": true, "sortBy": [{"displayName": "CPU (m)", "desc": true}]},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${ds_pods}"}, "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"${namespace}\", container!=\"\", container!=\"POD\"}[5m])) * 1000", "format": "table", "instant": true, "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${ds_pods}"}, "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"${namespace}\", container!=\"\", container!=\"POD\"}) / 1024 / 1024", "format": "table", "instant": true, "refId": "B"}
      ],
      "transformations": [
        {"id": "merge"},
        {"id": "organize", "options": {"excludeByName": {"Time": true}, "renameByName": {"Value #A": "CPU (m)", "Value #B": "Memory (MB)", "pod": "Pod"}}}
      ],
      "title": "📋 Pod Resource Usage — ${namespace}",
      "type": "table"
    }
  ]
}
